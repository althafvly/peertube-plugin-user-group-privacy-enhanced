{
  "name": "peertube-plugin-user-group-privacy-enhanced",
  "description": "A Peertube Plugin to define groups of users and then share videos only with certain groups",
  "version": "1.0.0",
  "license": "AGPL-3.0",
  "author": {
    "name": "Robin Niemann",
    "url": "https://github.com/RobinNiemann"
  },
  "bugs": "https://github.com/RobinNiemann/peertube-plugin-user-group-privacy-enhanced/issues",
  "clientScripts": [
    {
      "script": "dist/client/common-client-plugin.js",
      "scopes": [
        "common"
      ]
    },
    {
      "script": "dist/client/video-edit.js",
      "scopes": [
        "video-edit"
      ]
    }
  ],
  "css": [
    "dist/assets/style.css"
  ],
  "engine": {
    "peertube": ">=7.0.0"
  },
  "homepage": "https://github.com/RobinNiemann/peertube-plugin-user-group-privacy-enhanced",
  "keywords": [
    "peertube",
    "plugin"
  ],
  "library": "./dist/server/main.js",
  "scripts": {
    "clean": "rm -rf dist/*",
    "prepare": "npm run build",
    "check:client:tsc": "npx tsc --p client/tsconfig.json --noEmit",
    "build:server": "npx tsc --build server/tsconfig.json",
    "build:client": "node ./scripts/build.js",
    "build:styles": "npx sass --no-source-map assets:dist/assets",
    "build": "npm-run-all -s clean check:client:tsc -p build:server build:client build:styles",
    "lint:script": "npx eslint --ext .ts --ext .js .",
    "lint:styles": "stylelint 'assets/**/*.scss'",
    "test": "npm-run-all -p lint:script lint:styles",
    "cli:uninstall": "npx peertube-cli plugins uninstall --npm-name peertube-plugin-user-group-privacy-enhanced",
    "cli:install": "npx peertube-cli plugins install --path //plugin/peertube-plugin-user-group-privacy-enhanced",
    "cli:reinstall": "npm-run-all -p cli:uninstall build -s cli:install"
  },
  "staticDirs": {
    "images": "public/images"
  },
  "translations": {
    "de": "./languages/de.json"
  },
  "devDependencies": {
    "@peertube/peertube-types": "^7.0.0",
    "@tsconfig/node16": "^1.0.3",
    "@types/jest": "^29.5.14",
    "@typescript-eslint/eslint-plugin": "^5.33.0",
    "@typescript-eslint/parser": "^5.33.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.21.0",
    "eslint-config-standard-with-typescript": "^22.0.0",
    "jest": "^29.7.0",
    "npm-run-all": "^4.1.5",
    "sass": "^1.54.5",
    "stylelint": "^14.11.0",
    "stylelint-config-recommended-scss": "^7.0.0",
    "stylelint-config-standard-scss": "^5.0.0",
    "ts-jest": "^29.3.1",
    "typescript": "^4.7.4"
  },
  "dependencies": {
    "short-uuid": "^5.2.0",
    "yaml": "^2.8.0"
  }
}
